  },
  {
    "start": 661.32,
    "end": 664.1,
    "text": "QQ點COM就是它的一個運命",
    "segment_id": 283
  },
  {
    "start": 664.1,
    "end": 666.5,
    "text": "剛剛我們又說到電子郵件",
