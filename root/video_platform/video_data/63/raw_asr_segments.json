  },
  {
    "start": 668.42,
    "end": 670.06,
    "text": "在發送方的時候",
    "segment_id": 286
  },
  {
    "start": 670.06,
    "end": 673.56,
    "text": "它使用到的協議叫SNTTP協議",
    "segment_id": 287
  },
  {
    "start": 673.56,
    "end": 675.32,
    "text": "在接收方的時候",
    "segment_id": 288
  },
  {
    "start": 675.32,
    "end": 676.62,
    "text": "使用到的這個協議",
    "segment_id": 289
  },
  {
    "start": 676.62,
    "end": 678.82,
    "text": "叫POP3協議",
    "segment_id": 290
  },
  {
    "start": 678.82,
    "end": 680.26,
    "text": "所以大家一定不要基本",
    "segment_id": 291
  },
  {
    "start": 680.26,
    "end": 684.32,
    "text": "在發送方使用的是SNTTP",
    "segment_id": 292
  },
  {
    "start": 684.32,
    "end": 687.42,
    "text": "接收方使用到的是POP3",
