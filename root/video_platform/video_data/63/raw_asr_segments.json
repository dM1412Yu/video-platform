    "start": 647.44,
    "end": 649.44,
    "text": "是不是就前面是你的QQ號",
    "segment_id": 276
  },
  {
    "start": 649.44,
    "end": 650.94,
    "text": "後面是HTTP",
    "segment_id": 277
  },
  {
    "start": 650.94,
    "end": 653.02,
    "text": "然後QQ點COM",
    "segment_id": 278
  },
  {
    "start": 653.76,
    "end": 656.1,
    "text": "這個Q號就是你的一個用顧名",
    "segment_id": 279
  },
  {
    "start": 656.1,
    "end": 658.24,
    "text": "這一個後面的郵件",
    "segment_id": 280
  },
  {
    "start": 658.24,
    "end": 659.74,
    "text": "服務器的一個運命",
    "segment_id": 281
  },
  {
    "start": 659.74,
    "end": 661.32,
    "text": "你使用的是QQ有像",
