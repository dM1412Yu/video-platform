  },
  {
    "start": 694.96,
    "end": 696.98,
    "text": "這個端口號是不一樣的",
    "segment_id": 297
  },
  {
    "start": 696.98,
    "end": 700.16,
    "text": "對於發送方它的一個TCP連接端口號",
