 },\n  {\n    "start_time": 85.94,\n    "end_time": 87.68,\n    "text": "DNS運民系統"\n  },\n  {\n    "start_time": 87.68,\n    "end_time": 92.7,\n    "text": "也就是說會提取你這個網址裡面的這個運名"\n  },\n  {\n    "start_time": 92.7,\n    "end_time": 94.74,\n    "text": "然後通過DNS"\n  },\n  {\n    "start_time": 94.74,\n    "end_time": 96.02,\n    "text": "把這個運名"\n  },\n  {\n    "start_time": 96.02,\n    "end_time": 98.8,\n    "text": "轉換為IPD值發送給流冷器"\n  },\n  {\n    "start_time": 98.8,\n    "end_time": 101.32,\n    "text": "然後流冷器再通過這個IPD值"\n  },\n  {\n    "start_time": 101.32,\n    "end_time": 103.82,\n    "text": "去和互聯網之間進行通信"\n  },\n  {\n    "start_time": 103.82,\n    "end_time": 106.62,\n    "text": "所以DNS它的一個功能呢"\n  },\n  {\n    "start_time": 106.62,\n    "end_time": 109.7,\n    "text": "就是向運名轉換為IPD值"\n  },\n  {\n    "start_time": 109.7,\n    "end_time": 112.36,\n    "text": "那常見的初題方式也是選擇體"\n  },\n  {\n    "start_time": 112.94,\n    "end_time": 114.16,\n    "text": "或者是全控體"\n  },\n  {\n    "start_time": 114.92,\n    "end_time": 118.88,\n    "text": "那再接下來我們看一下運名它的一個結構"\n  },\n  {\n    "start_time": 118.88,\n    "end_time": 121.12,\n    "text": "那它一共是有三級結構"\n  },\n  {\n    "start_time": 121.12,\n    "end_time": 123.36,\n    "text": "那最右邊呢是一個頂級運名"\n  },\n  {\n    "start_time": 123.36,\n    "end_time": 125.58,\n    "text": "那中間是二級運名"\n  },\n  {\n    "start_time": 125.58,\n    "end_time": 128.14,\n    "text": "然後最左邊是一個三級運名"\n  },\n  {\n    "start_time": 128.14,\n    "end_time": 131.98,\n    "text": "並且它最右邊的這個級別是最高的"\n  },\n  {\n    "start_time": 131.98,\n    "end_time": 134.08,\n    "text": "從右到左它的級別呢"\n  },\n  {\n    "start_time": 134.08,\n    "end_time": 135.92,\n    "text": "是越來越低的"\n  },\n  {\n    "start_time": 137.98,\n    "end_time": 139.64,\n    "text": "對運名進行分類"\n  },\n  {\n    "start_time": 139.64,\n    "end_time": 141.08,\n    "text": "我們可以這麼來進行分"\n  },\n  {\n    "start_time": 141.08,\n    "end_time": 144.1,\n    "text": "首先第一種是原先的這個頂級運名"\n  },\n  {\n    "start_time": 144.1,\n    "end_time": 148.38,\n    "text": "它可以分成國家頂級運名和通用的頂級運名"\n  },\n  {\n    "start_time": 148.38,\n    "end_time": 150.74,\n    "text": "那國家的上面就比較好記憶"\n  },\n  {\n    "start_time": 150.74,\n    "end_time": 153.74,\n    "text": "你想中國它的一個英文是不是China"\n  },\n  {\n    "start_time": 153.74,\n    "end_time": 156.44,\n    "text": "所以說寫就說寫成了CN"\n  },\n  {\n    "start_time": 156.44,\n    "end_time": 159.18,\n    "text": "這個就是中國它的一個國家頂級運名"\n  },\n  {\n    "start_time": 159.18,\n    "end_time": 161.0,\n    "text": "那美國呢是US"\n  },\n  {\n    "start_time": 161.0,\n    "end_time": 163.2,\n    "text": "英國呢是UK"\n  },\n  {\n    "start_time": 163.2,\n    "end_time": 167.28,\n    "text": "那在這三個裡面我們比較常見的初題方式"\n  },\n  {\n    "start_time": 167.28,\n    "end_time": 168.64,\n    "text": "大陸數是考CN"\n  },\n  {\n    "start_time": 168.64,\n    "end_time": 171.96,\n    "text": "你知道CN還代表的是中國就可以了"\n  },\n  {\n    "start_time": 171.96,\n    "end_time": 174.72,\n    "text": "然後從用頂級運名是有四個"\n  },\n  {\n    "start_time": 174.72,\n    "end_time": 177.92,\n    "text": "在這四個裡面比較常考的是前三個"\n  },\n  {\n    "start_time": 177.92,\n    "end_time": 179.7,\n    "text": "那第一個這個COM"\n  },\n  {\n    "start_time": 179.7,\n    "end_time": 181.8,\n    "text": "它就是公司企業"\n  },\n  {\n    "start_time": 181.8,\n    "end_time": 184.76,\n    "text": "那這個EDU代表的就是交易機構"\n  },\n  {\n    "start_time": 184.76,\n    "end_time": 186.5,\n    "text": "因為它是這個Ibuction"\n  },\n  {\n    "start_time": 186.5,\n    "end_time": 188.44,\n    "text": "這個教育它的一個縮寫嘛"\n  },\n  {\n    "start_time": 188.44,\n    "end_time": 191.16,\n    "text": "所以EDU代表的就是交易機構"\n  },\n  {\n    "start_time": 191.16,\n    "end_time": 194.22,\n    "text": "那Gov代表的就是政府部門"\n  },\n  {\n    "start_time": 194.22,\n    "end_time": 196.7,\n    "text": "同樣的也是這個英文Gavement"\n  },\n  {\n    "start_time": 196.7,\n    "end_time": 198.56,\n    "text": "它的一個縮寫"\n  },\n  {\n    "start_time": 199.28,\n    "end_time": 202.46,\n    "text": "所以這三個是要求大家一定要記住的"\n  },\n  {\n    "start_time": 202.46,\n    "end_time": 204.22,\n    "text": "我們初題的時候會以選擇"\n  },\n  {\n    "start_time": 204.22,\n    "end_time": 205.56,\n    "text": "選擇形式進行初題"\n  },\n  {\n    "start_time": 205.56,\n    "end_time": 209.16,\n    "text": "給你一個譽名問你它代表的是公司"\n  },\n  {\n    "start_time": 209.16,\n    "end_time": 211.54,\n    "text": "還是交易機構還是政府部門"\n  },\n  {\n    "start_time": 211.54,\n    "end_time": 214.94,\n    "text": "那一定要知道看到Gov想到的是政府"\n  },\n  {\n    "start_time": 214.94,\n    "end_time": 217.5,\n    "text": "看到EDU想到的呢就是教育"\n  },\n  {\n    "start_time": 217.5,\n    "end_time": 220.3,\n    "text": "那第二種分類方式是我國"\n  },\n  {\n    "start_time": 220.3,\n    "end_time": 222.86,\n    "text": "它會把二級譽名化成兩類"\n  },\n  {\n    "start_time": 222.86,\n    "end_time": 224.3,\n    "text": "一個是類別譽名"\n  },\n  {\n    "start_time": 224.3,\n    "end_time": 226.2,\n    "text": "還有一個是行政區譽名"\n  },\n  {\n    "start_time": 226.2,\n    "end_time": 228.98,\n    "text": "那這個類別譽名和咱們發採講的"\n  },\n  {\n    "start_time": 228.98,\n    "end_time": 231.24,\n    "text": "這個通用電機譽名其實比較類似的"\n  },\n  {\n    "start_time": 231.24,\n    "end_time": 235.24,\n    "text": "也是一個有四個我們常見的也是後三個"\n  },\n  {\n    "start_time": 235.24,\n    "end_time": 236.16,\n    "text": "那這一個呢"\n  },\n  {\n    "start_time": 236.16,\n    "end_time": 238.76,\n    "text": "COM它代表的就是公司企業"\n  },\n  {\n    "start_time": 238.76,\n    "end_time": 241.0,\n    "text": "EDU代表的是交易機構"\n  },\n  {\n    "start_time": 241.0,\n    "end_time": 243.9,\n    "text": "Gov代表的就是中國的政府機構"\n  },\n  {\n    "start_time": 243.9,\n    "end_time": 245.54,\n    "text": "它和高殘了三個"\n  },\n  {\n    "start_time": 245.54,\n    "end_time": 248.32,\n    "text": "通用電機譽名我們可以在一起記憶"\n  },\n  {\n    "start_time": 248.32,\n    "end_time": 250.56,\n    "text": "看到COM想到公司企業"\n  },\n  {\n    "start_time": 250.56,\n    "end_time": 252.76,\n    "text": "看到EDU想到交易機構"\n  },\n  {\n    "start_time": 252.76,\n    "end_time": 255.66,\n    "text": "看到Gov想到的就是政府機構"\n  },\n  {\n    "start_time": 255.66,\n    "end_time": 258.06,\n    "text": "那第二類就是行政區譽名"\n  },\n  {\n    "start_time": 258.06,\n    "end_time": 260.6,\n    "text": "它是使用於我不各手和自治區的"\n  },\n  {\n    "start_time": 260.6,\n    "end_time": 263.28,\n    "text": "比如說北京它的一個縮顯的就是BG"\n  },\n  {\n    "start_time": 263.28,\n    "end_time": 265.58,\n    "text": "那上海它的縮顯就是SH"\n  },\n  {\n    "start_time": 265.58,\n    "end_time": 267.92,\n    "text": "但是行政區譽名這個一般"\n  },\n  {\n    "start_time": 267.92,\n    "end_time": 269.18,\n    "text": "可能激劣會小一些"\n  },\n  {\n    "start_time": 269.18,\n    "end_time": 271.58,\n    "text": "但是如果出題大家也比較好做"\n  },\n  {\n    "start_time": 271.58,\n    "end_time": 274.52,\n    "text": "因為都是中文它的一個縮顯"\n  },\n  {\n    "start_time": 275.94,\n    "end_time": 278.08,\n    "text": "好那下面我們就看兩道題"\n  },\n  {\n    "start_time": 278.08,\n    "end_time": 279.92,\n    "text": "鞏固一下考點1的內容"\n  },\n  {\n    "start_time": 279.92,\n    "end_time": 283.14,\n    "text": "問能夠把Bin名轉換為網路"\n  },\n  {\n    "start_time": 283.14,\n    "end_time": 285.8,\n    "text": "如果可以識別的IPD值的協議是哪一個"\n  },\n  {\n    "start_time": 285.8,\n    "end_time": 288.76,\n    "text": "剛剛我們說了是譽名系統DNS"\n  },\n  {\n    "start_time": 288.76,\n    "end_time": 291.08,\n    "text": "它的一個功能就是將譽名"\n  },\n  {\n    "start_time": 291.08,\n    "end_time": 292.72,\n    "text": "轉換為IPD值"\n  },\n  {\n    "start_time": 293.36,\n    "end_time": 295.54,\n    "text": "第2 下列譽名"\n  },\n  {\n    "start_time": 295.54,\n    "end_time": 298.62,\n    "text": "最有可能屬於是政府機構的事"\n  },\n  {\n    "start_time": 298.62,\n    "end_time": 301.32,\n    "text": "但你看到政府是不是想到的就是Gov"\n  },\n  {\n    "start_time": 301.32,\n    "end_time": 304.12,\n    "text": "那你看下面哪一個網站帶Gov"\n  },\n  {\n    "start_time": 304.12,\n    "end_time": 305.92,\n    "text": "是不是只有選項C"\n  },\n  {\n    "start_time": 305.92,\n    "end_time": 307.92,\n    "text": "所以答案就是C選項"\n  },\n  {\n    "start_time": 309.06,\n    "end_time": 313.06,\n    "text": "考點2 文件傳輸協議"\n  },\n  {\n    "start_time": 313.06,\n    "end_time": 315.2,\n    "text": "它的一個縮顯是FTP"\n  },\n  {\n    "start_time": 315.2,\n    "end_time": 318.54,\n    "text": "這個F它就是文件Fell的一個縮顯"\n  },\n  {\n    "start_time": 319.06,\n    "end_time": 322.12,\n    "text": "那FTP它採用的工作方式是"\n  },\n  {\n    "start_time": 322.12,\n    "end_time": 323.96,\n    "text": "客戶服務器方式"\n  },\n  {\n    "start_time": 323.96,\n    "end_time": 326.34,\n    "text": "那我們在使用這個協議的時候"\n  },\n  {\n    "start_time": 326.34,\n    "end_time": 327.78,\n    "text": "它所應用到的"\n  },\n  {\n    "start_time": 327.78,\n    "end_time": 331.94,\n    "text": "是下面運輸層的TCP協議"\n  },\n  {\n    "start_time": 331.94,\n    "end_time": 335.9,\n    "text": "因為我們知道運輸層是不是在應用層的一個下方的"\n  },\n  {\n    "start_time": 335.9,\n    "end_time": 339.7,\n    "text": "所以應用層的協議會使用到運輸層的一個協議"\n  },\n  {\n    "start_time": 339.7,\n    "end_time": 340.84,\n    "text": "那運輸層有兩個"\n  },\n  {\n    "start_time": 340.84,\n    "end_time": 343.78,\n    "text": "一個是TCP協議還有一個是UDP協議"\n  },\n  {\n    "start_time": 343.78,\n    "end_time": 346.62,\n    "text": "那對於這個FTP這個協議而言"\n  },\n  {\n    "start_time": 346.62,\n    "end_time": 349.44,\n    "text": "它使用到的是PCP這個協議"\n  },\n  {\n    "start_time": 349.44,\n    "end_time": 352.72,\n    "text": "既然使用的是TCP協議它就需要建立連接"\n  },\n  {\n    "start_time": 352.72,\n    "end_time": 355.74,\n    "text": "但是對於這個FTP這個協議而言"\n  },\n  {\n    "start_time": 355.74,\n    "end_time": 358.62,\n    "text": "它是會有兩個PCP的連接"\n  },\n  {\n    "start_time": 358.62,\n    "end_time": 360.36,\n    "text": "一個是控制進程"\n  },\n  {\n    "start_time": 360.36,\n    "end_time": 363.14,\n    "text": "還有一個是數據傳輸進程"\n  },\n  {\n    "start_time": 363.14,\n    "end_time": 365.38,\n    "text": "那這兩個TCP連接"\n  },\n  {\n    "start_time": 365.38,\n    "end_time": 367.88,\n    "text": "它們連接的端口號也是不一樣的"\n  },\n  {\n    "start_time": 367.88,\n    "end_time": 369.28,\n    "text": "對於控制進程"\n  },\n  {\n    "start_time": 369.28,\n    "end_time": 371.54,\n    "text": "那它連接的那就是21"\n  },\n  {\n    "start_time": 371.54,\n    "end_time": 373.98,\n    "text": "對於數據傳輸進程"\n  },\n  {\n    "start_time": 373.98,\n    "end_time": 375.24,\n    "text": "它連接的端口號"\n  },\n  {\n    "start_time": 375.24,\n    "end_time": 377.88,\n    "text": "那就是20這個大家一定要記住"\n  },\n  {\n    "start_time": 377.88,\n    "end_time": 379.04,\n    "text": "我們選擇體裡面"\n  },\n  {\n    "start_time": 379.04,\n    "end_time": 381.28,\n    "text": "會以這種方式進行出體驗"\n  },\n  {\n    "start_time": 381.28,\n    "end_time": 383.62,\n    "text": "那你也可以這樣想控制進程"\n  },\n  {\n    "start_time": 383.62,\n    "end_time": 386.34,\n    "text": "它是不是在數據進程上訪"\n  },\n  {\n    "start_time": 386.88,\n    "end_time": 390.12,\n    "text": "所以說它這個21要比20要大一位"\n  },\n  {\n    "start_time": 390.12,\n    "end_time": 392.44,\n    "text": "也就是這樣連想去記憶一下"\n  },\n  {\n    "start_time": 392.44,\n    "end_time": 394.16,\n    "text": "會比較好記憶一下"\n  },\n  {\n    "start_time": 395.5,\n    "end_time": 396.84,\n    "text": "那我們來看一道題"\n  },\n  {\n    "start_time": 396.84,\n    "end_time": 398.52,\n    "text": "鞏固一下考點2的內容"\n  },\n  {\n    "start_time": 398.52,\n    "end_time": 401.02,\n    "text": "說FTP還有兩個端口"\n  },\n  {\n    "start_time": 401.02,\n    "end_time": 402.94,\n    "text": "用做控制連接的"\n  },\n  {\n    "start_time": 402.94,\n    "end_time": 404.3,\n    "text": "挖人端口號是多少"\n  },\n  {\n    "start_time": 404.3,\n    "end_time": 406.42,\n    "text": "那剛剛我們說了控制連接"\n  },\n  {\n    "start_time": 406.42,\n    "end_time": 407.68,\n    "text": "它是不是在上方"\n  },\n  {\n    "start_time": 407.68,\n    "end_time": 409.94,\n    "text": "然後這個數據傳輸的這一條"\n  },\n  {\n    "start_time": 409.94,\n    "end_time": 412.38,\n    "text": "它是在控制的這個進程下滅"\n  },\n  {\n    "start_time": 412.38,\n    "end_time": 415.54,\n    "text": "所以說控制進程連接的就是21"\n  },\n  {\n    "start_time": 415.54,\n    "end_time": 417.28,\n    "text": "剛口號那這個數據呢"\n  },\n  {\n    "start_time": 417.28,\n    "end_time": 418.64,\n    "text": "連接的就是20"\n  },\n  {\n    "start_time": 418.64,\n    "end_time": 420.96,\n    "text": "那答案就是立選項"\n  },\n  {\n    "start_time": 422.02,\n    "end_time": 423.14,\n    "text": "好考點3"\n  },\n  {\n    "start_time": 423.14,\n    "end_time": 425.26,\n    "text": "遠程中方協議TellNights"\n  },\n  {\n    "start_time": 425.26,\n    "end_time": 427.56,\n    "text": "那對於這個遠程中方協議"\n  },\n  {\n    "start_time": 427.56,\n    "end_time": 430.06,\n    "text": "我們只需要知道它的一個功能就行了"\n  },\n  {\n    "start_time": 430.06,\n    "end_time": 432.96,\n    "text": "它是用於安全的這個遠程登錄的"\n  },\n  {\n    "start_time": 432.96,\n    "end_time": 434.86,\n    "text": "所以當你在看到"\n  },\n  {\n    "start_time": 434.86,\n    "end_time": 436.88,\n    "text": "凡是為你遠程登錄"\n  },\n  {\n    "start_time": 436.88,\n    "end_time": 439.16,\n    "text": "用哪個協議你就想到TellNights"\n  },\n  {\n    "start_time": 439.16,\n    "end_time": 440.84,\n    "text": "我們可以聯想記憶"\n  },\n  {\n    "start_time": 440.84,\n    "end_time": 442.46,\n    "text": "一般說遠是不是都說"\n  },\n  {\n    "start_time": 442.46,\n    "end_time": 443.82,\n    "text": "它也遠了這個地方"\n  },\n  {\n    "start_time": 443.82,\n    "end_time": 444.18,\n    "text": "對吧"\n  },\n  {\n    "start_time": 444.18,\n    "end_time": 445.82,\n    "text": "那你看太遠了"\n  },\n  {\n    "start_time": 445.82,\n    "end_time": 448.82,\n    "text": "它的中文的這個第一個手絲模是不是T"\n  },\n  {\n    "start_time": 448.82,\n    "end_time": 451.18,\n    "text": "那和這個TellNights這個協議的"\n  },\n  {\n    "start_time": 451.18,\n    "end_time": 452.48,\n    "text": "第一個絲模是一樣的"\n  },\n  {\n    "start_time": 452.48,\n    "end_time": 454.46,\n    "text": "所以我們可以這樣聯想去記憶"\n  },\n  {\n    "start_time": 454.46,\n    "end_time": 458.12,\n    "text": "TellNights它就是進行這個遠程登錄的"\n  },\n  {\n    "start_time": 459.22,\n    "end_time": 461.42,\n    "text": "考點4萬為往3W"\n  },\n  {\n    "start_time": 461.42,\n    "end_time": 463.38,\n    "text": "那這個呢也是我們本章"\n  },\n  {\n    "start_time": 463.38,\n    "end_time": 466.3,\n    "text": "會出奇頻率比較高的一個考點"\n  },\n  {\n    "start_time": 466.3,\n    "end_time": 469.68,\n    "text": "那對於萬為往首先我們要掌握它的3個部分"\n  },\n  {\n    "start_time": 469.68,\n    "end_time": 472.26,\n    "text": "第一個呢就是統一資源並衛福"\n  },\n  {\n    "start_time": 472.26,\n    "end_time": 472.92,\n    "text": "URO"\n  },\n  {\n    "start_time": 473.46,\n    "end_time": 474.92,\n    "text": "這個是它的一個格式"\n  },\n  {\n    "start_time": 474.92,\n    "end_time": 477.68,\n    "text": "最前面是你使用到的哪一種協議"\n  },\n  {\n    "start_time": 477.68,\n    "end_time": 479.14,\n    "text": "然後冒號雙協杠"\n  },\n  {\n    "start_time": 479.14,\n    "end_time": 481.54,\n    "text": "後面是有一個主機和這個斑口"\n  },\n  {\n    "start_time": 481.54,\n    "end_time": 484.94,\n    "text": "只是這個端口號我們往往是省月的"\n  },\n  {\n    "start_time": 484.94,\n    "end_time": 487.0,\n    "text": "然後再往後是它的一個路徑"\n  },\n  {\n    "start_time": 487.0,\n    "end_time": 489.08,\n    "text": "我們可以看一下下面這張圖"\n  },\n  {\n    "start_time": 489.08,\n    "end_time": 491.94,\n    "text": "這個呢是我們打開BDBD這個網站"\n  },\n  {\n    "start_time": 491.94,\n    "end_time": 494.62,\n    "text": "當你在一個裡面去搜索"\n  },\n  {\n    "start_time": 494.62,\n    "end_time": 496.36,\n    "text": "C程序設計三小時"\n  },\n  {\n    "start_time": 496.36,\n    "end_time": 497.9,\n    "text": "寄目不挖的時候"\n  },\n  {\n    "start_time": 497.9,\n    "end_time": 499.02,\n    "text": "它彈出來的"\n  },\n  {\n    "start_time": 499.5,\n    "end_time": 501.56,\n    "text": "我們高速方的一個課程"\n  },\n  {\n    "start_time": 501.56,\n    "end_time": 504.86,\n    "text": "那它這個課程它的一個定衛服"\n  },\n  {\n    "start_time": 504.86,\n    "end_time": 508.16,\n    "text": "我們來看一下這個BDBD點CO矮目"\n  },\n  {\n    "start_time": 508.16,\n    "end_time": 509.92,\n    "text": "它指的就是這個主機"\n  },\n  {\n    "start_time": 509.92,\n    "end_time": 512.46,\n    "text": "後面這個協杠後面的這一創"\n  },\n  {\n    "start_time": 512.46,\n    "end_time": 514.5,\n    "text": "就指的是它的一個路徑"\n  },\n  {\n    "start_time": 514.5,\n    "end_time": 517.44,\n    "text": "那這個呢就是一個統一資源並衛福"\n  },\n  {\n    "start_time": 517.44,\n    "end_time": 519.54,\n    "text": "那它的第二個組成部分"\n  },\n  {\n    "start_time": 519.54,\n    "end_time": 522.26,\n    "text": "是這個超紋本傳送協議HTTP"\n  },\n  {\n    "start_time": 522.92,\n    "end_time": 524.6,\n    "text": "也就是說在這個界面上"\n  },\n  {\n    "start_time": 524.6,\n    "end_time": 526.1,\n    "text": "不管是首頁也好"\n  },\n  {\n    "start_time": 526.1,\n    "end_time": 527.02,\n    "text": "直播也好"\n  },\n  {\n    "start_time": 527.02,\n    "end_time": 528.34,\n    "text": "遊戲中心也好"\n  },\n  {\n    "start_time": 528.34,\n    "end_time": 530.24,\n    "text": "它都是一個一個超鏈階"\n  },\n  {\n    "start_time": 530.24,\n    "end_time": 532.76,\n    "text": "我們一點就可以打開一個網址"\n  },\n  {\n    "start_time": 532.76,\n    "end_time": 536.54,\n    "text": "所以說超紋本傳送協議HTTP"\n  },\n  {\n    "start_time": 536.54,\n    "end_time": 539.38,\n    "text": "它是這個超鏈階傳送數據的一個"\n  },\n  {\n    "start_time": 539.38,\n    "end_time": 539.98,\n    "text": "方式"\n  },\n  {\n    "start_time": 539.98,\n    "end_time": 541.48,\n    "text": "那它使用的呢"\n  },\n  {\n    "start_time": 541.48,\n    "end_time": 544.06,\n    "text": "也是這個PCP這個協議"\n  },\n  {\n    "start_time": 544.06,\n    "end_time": 546.18,\n    "text": "那它就要有一個端口號"\n  },\n  {\n    "start_time": 546.18,\n    "end_time": 548.82,\n    "text": "那這個端口號呢是80"\n  },\n  {\n    "start_time": 549.72,\n    "end_time": 552.6,\n    "text": "第三個組成部分是超紋本標記語"\n  },\n  {\n    "start_time": 552.6,\n    "end_time": 553.56,\n    "text": "HTML"\n  },\n  {\n    "start_time": 553.56,\n    "end_time": 556.5,\n    "text": "它所指的是這個數據呈現了一個方式"\n  },\n  {\n    "start_time": 556.5,\n    "end_time": 557.98,\n    "text": "那對於這個網頁"\n  },\n  {\n    "start_time": 557.98,\n    "end_time": 560.26,\n    "text": "我們直接右鍵給它去進行一個保存"\n  },\n  {\n    "start_time": 560.26,\n    "end_time": 562.08,\n    "text": "保存下來的這個壓塑包裡"\n  },\n  {\n    "start_time": 562.08,\n    "end_time": 565.76,\n    "text": "我們會找到這麼兩個HTML文件"\n  },\n  {\n    "start_time": 565.76,\n    "end_time": 567.36,\n    "text": "所以這個就是萬為往"\n  },\n  {\n    "start_time": 567.36,\n    "end_time": 569.56,\n    "text": "它這個超紋本標記語言"\n  },\n  {\n    "start_time": 569.56,\n    "end_time": 571.82,\n    "text": "那對於萬為往這三個組成部分"\n  },\n  {\n    "start_time": 571.82,\n    "end_time": 574.56,\n    "text": "我們要知道它的一個統一資源"\n  },\n  {\n    "start_time": 574.56,\n    "end_time": 576.56,\n    "text": "定位服UR的格式"\n  },\n  {\n    "start_time": 576.56,\n    "end_time": 577.72,\n    "text": "那主持之外"\n  },\n  {\n    "start_time": 577.72,\n    "end_time": 578.5,\n    "text": "你還要知道"\n  },\n  {\n    "start_time": 578.5,\n    "end_time": 580.98,\n    "text": "萬為往它的超紋本傳送協議"\n  },\n  {\n    "start_time": 580.98,\n    "end_time": 582.48,\n    "text": "用的是HTTP"\n  },\n  {\n    "start_time": 582.48,\n    "end_time": 586.28,\n    "text": "那HTTP又是使用的TCP的一個連接"\n  },\n  {\n    "start_time": 586.28,\n    "end_time": 589.14,\n    "text": "那它和建立這個TCP連接的時候"\n  },\n  {\n    "start_time": 589.14,\n    "end_time": 591.22,\n    "text": "使用的端口號呢是80"\n  },\n  {\n    "start_time": 591.74,\n    "end_time": 594.68,\n    "text": "那第三個就是這個超紋標記語言"\n  },\n  {\n    "start_time": 594.68,\n    "end_time": 596.3,\n    "text": "使用的是HTML"\n  },\n  {\n    "start_time": 596.96,\n    "end_time": 599.02,\n    "text": "那下面我們來看一道CT"\n  },\n  {\n    "start_time": 599.02,\n    "end_time": 600.82,\n    "text": "恐怖一下考點4的內容"\n  },\n  {\n    "start_time": 600.82,\n    "end_time": 603.84,\n    "text": "說三W網頁文件的編寫語言"\n  },\n  {\n    "start_time": 603.84,\n    "end_time": 607.18,\n    "text": "以及它相應的這個支持協議是哪一個"\n  },\n  {\n    "start_time": 607.18,\n    "end_time": 608.46,\n    "text": "那編寫語言"\n  },\n  {\n    "start_time": 608.46,\n    "end_time": 610.58,\n    "text": "咱們剛剛說了是HTML"\n  },\n  {\n    "start_time": 611.04,\n    "end_time": 614.16,\n    "text": "那這個相應的支持協議是HTTP"\n  },\n  {\n    "start_time": 614.16,\n    "end_time": 616.46,\n    "text": "所以答案就是C選項"\n  },\n  {\n    "start_time": 618.02,\n    "end_time": 619.66,\n    "text": "考點5電子郵件"\n  },\n  {\n    "start_time": 619.66,\n    "end_time": 621.28,\n    "text": "對於電子郵件這兒"\n  },\n  {\n    "start_time": 621.28,\n    "end_time": 622.64,\n    "text": "我們需要找我兩個支持"\n  },\n  {\n    "start_time": 622.64,\n    "end_time": 625.26,\n    "text": "第一個就是電子郵件它的一個格式"\n  },\n  {\n    "start_time": 625.26,\n    "end_time": 627.06,\n    "text": "第二個就是電子郵件"\n  },\n  {\n    "start_time": 627.06,\n    "end_time": 629.24,\n    "text": "它不是分為發送方和接收方法"\n  },\n  {\n    "start_time": 629.24,\n    "end_time": 632.06,\n    "text": "在發送方我們使用了哪一個協議"\n  },\n  {\n    "start_time": 632.06,\n    "end_time": 634.38,\n    "text": "在接收方又使用了哪一個協議"\n  },\n  {\n    "start_time": 634.38,\n    "end_time": 635.82,\n    "text": "好我們先來看一下"\n  },\n  {\n    "start_time": 635.82,\n    "end_time": 637.76,\n    "text": "電子郵件它的一個格式"\n  },\n  {\n    "start_time": 637.76,\n    "end_time": 639.92,\n    "text": "就是用顧名然後去HT"\n  },\n  {\n    "start_time": 639.92,\n    "end_time": 641.68,\n    "text": "郵件服務器的一個運命"\n  },\n  {\n    "start_time": 642.26,\n    "end_time": 643.22,\n    "text": "這個咱們比較好記"\n  },\n  {\n    "start_time": 643.22,\n    "end_time": 644.32,\n    "text": "大家這個QQ號"\n  },\n  {\n    "start_time": 644.32,\n    "end_time": 645.58,\n    "text": "也都有這個Q郵箱"\n  },\n  {\n    "start_time": 645.58,\n    "end_time": 645.92,\n    "text": "對吧"\n  },\n  {\n    "start_time": 645.92,\n    "end_time": 647.44,\n    "text": "你看你的QQ郵箱"\n  },\n  {\n    "start_time": 647.44,\n    "end_time": 649.44,\n    "text": "是不是就前面是你的QQ號"\n  },\n  {\n    "start_time": 649.44,\n    "end_time": 650.94,\n    "text": "後面是HTTP"\n  },\n  {\n    "start_time": 650.94,\n    "end_time": 653.02,\n    "text": "然後QQ點COM"\n  },\n  {\n    "start_time": 653.76,\n    "end_time": 656.1,\n    "text": "這個Q號就是你的一個用顧名"\n  },\n  {\n    "start_time": 656.1,\n    "end_time": 658.24,\n    "text": "這一個後面的郵件"\n  },\n  {\n    "start_time": 658.24,\n    "end_time": 659.74,\n    "text": "服務器的一個運命"\n  },\n  {\n    "start_time": 659.74,\n    "end_time": 661.32,\n    "text": "你使用的是QQ有像"\n  },\n  {\n    "start_time": 661.32,\n    "end_time": 664.1,\n    "text": "QQ點COM就是它的一個運命"\n  },\n  {\n    "start_time": 664.1,\n    "end_time": 666.5,\n    "text": "剛剛我們又說到電子郵件"\n  },\n  {\n    "start_time": 666.5,\n    "end_time": 668.42,\n    "text": "分為發送方和接收方"\n  },\n  {\n    "start_time": 668.42,\n    "end_time": 670.06,\n    "text": "在發送方的時候"\n  },\n  {\n    "start_time": 670.06,\n    "end_time": 673.56,\n    "text": "它使用到的協議叫SNTTP協議"\n  },\n  {\n    "start_time": 673.56,\n    "end_time": 675.32,\n    "text": "在接收方的時候"\n  },\n  {\n    "start_time": 675.32,\n    "end_time": 676.62,\n    "text": "使用到的這個協議"\n  },\n  {\n    "start_time": 676.62,\n    "end_time": 678.82,\n    "text": "叫POP3協議"\n  },\n  {\n    "start_time": 678.82,\n    "end_time": 680.26,\n    "text": "所以大家一定不要基本"\n  },\n  {\n    "start_time": 680.26,\n    "end_time": 684.32,\n    "text": "在發送方使用的是SNTTP"\n  },\n  {\n    "start_time": 684.32,\n    "end_time": 687.42,\n    "text": "接收方使用到的是POP3"\n  },\n  {\n    "start_time": 687.42,\n    "end_time": 689.02,\n    "text": "這兩個協議"\n  },\n  {\n    "start_time": 689.02,\n    "end_time": 692.38,\n    "text": "它們也是使用TCP去建立連接的"\n  },\n  {\n    "start_time": 692.38,\n    "end_time": 694.96,\n    "text": "但是它們在TCP連接時候"\n  },\n  {\n    "start_time": 694.96,\n    "end_time": 696.96,\n    "text": "這個端口號是不一樣的"\n  },\n  {\n    "start_time": 696.96,\n    "end_time": 700.16,\n    "text": "對於發送方它的一個TCP連接端口號"\n  },\n  {\n    "start_time": 700.16,\n    "end_time": 701.4,\n    "text": "是25"\n  },\n  {\n    "start_time": 701.9,\n    "end_time": 704.62,\n    "text": "接收方POP3的協議"\n  },\n  {\n    "start_time": 704.62,\n    "end_time": 707.14,\n    "text": "它和使用TCP連接的端口號"\n  },\n  {\n    "start_time": 707.14,\n    "end_time": 708.66,\n    "text": "是1100"\n  },\n  {\n    "start_time": 710.26,\n    "end_time": 712.4,\n    "text": "好下面我們來看一道例題"\n  },\n  {\n    "start_time": 712.4,\n    "end_time": 714.18,\n    "text": "鞏固一下烤點5的內容"\n  },\n  {\n    "start_time": 714.18,\n    "end_time": 717.28,\n    "text": "問下列用於接收電子郵件"\n  },\n  {\n    "start_time": 717.28,\n    "end_time": 718.94,\n    "text": "網絡協議是哪一個"\n  },\n  {\n    "start_time": 718.94,\n    "end_time": 720.88,\n    "text": "看清楚它們的是接收"\n  },\n  {\n    "start_time": 720.88,\n    "end_time": 723.02,\n    "text": "接收就是POP3"\n  },\n  {\n    "start_time": 723.02,\n    "end_time": 724.66,\n    "text": "所以答案是避選項"\n  },\n  {\n    "start_time": 725.44,\n    "end_time": 728.12,\n    "text": "烤點6動態主機配置協議"\n  },\n  {\n    "start_time": 728.12,\n    "end_time": 729.18,\n    "text": "DHCEP"\n  },\n  {\n    "start_time": 729.18,\n    "end_time": 733.7,\n    "text": "這個協議它就是用來自動去獲取IPD值的"\n  },\n  {\n    "start_time": 733.7,\n    "end_time": 736.08,\n    "text": "就是不用我們再去手工去配置了"\n  },\n  {\n    "start_time": 736.08,\n    "end_time": 738.28,\n    "text": "我可以自動地去獲取IPD值"\n  },\n  {\n    "start_time": 738.28,\n    "end_time": 740.1,\n    "text": "你只需要記住它的功能略銷"\n  },\n  {\n    "start_time": 740.1,\n    "end_time": 741.92,\n    "text": "讓我們常見的出題方式"\n  },\n  {\n    "start_time": 741.92,\n    "end_time": 743.08,\n    "text": "就是像利益一樣"\n  },\n  {\n    "start_time": 743.08,\n    "end_time": 744.56,\n    "text": "它會問你"\n  },\n  {\n    "start_time": 744.56,\n    "end_time": 747.16,\n    "text": "用於這個動態分配IPD值"\n  },\n  {\n    "start_time": 747.16,\n    "end_time": 749.12,\n    "text": "解決網絡地紙的衝突的協議"\n  },\n  {\n    "start_time": 749.12,\n    "end_time": 749.86,\n    "text": "是哪一個"\n  },\n  {\n    "start_time": 749.86,\n    "end_time": 752.2,\n    "text": "這個就是避HCEP"\n  },\n  {\n    "start_time": 752.2,\n    "end_time": 753.74,\n    "text": "我們可以這樣去記憶"\n  },\n  {\n    "start_time": 753.74,\n    "end_time": 755.32,\n    "text": "應該你看到CP"\n  },\n  {\n    "start_time": 755.8,\n    "end_time": 758.36,\n    "text": "你是不是在看電視的時候會課CP"\n  },\n  {\n    "start_time": 758.36,\n    "end_time": 760.66,\n    "text": "這個CP是我們自動去給它"\n  },\n  {\n    "start_time": 760.66,\n    "end_time": 761.84,\n    "text": "就是去分配的"\n  },\n  {\n    "start_time": 761.84,\n    "end_time": 762.28,\n    "text": "對吧"\n  },\n  {\n    "start_time": 762.28,\n    "end_time": 764.42,\n    "text": "今天你看到分配就想到CP"\n  },\n  {\n    "start_time": 764.42,\n    "end_time": 766.36,\n    "text": "所以答案就是A選項"\n  },\n  {\n    "start_time": 768.64,\n    "end_time": 771.96,\n    "text": "最後我們是把常見的應用層的這些協議"\n  },\n  {\n    "start_time": 771.96,\n    "end_time": 774.66,\n    "text": "它是使用的我們這個運輸層的"\n  },\n  {\n    "start_time": 774.66,\n    "end_time": 775.6,\n    "text": "哪一個協議"\n  },\n  {\n    "start_time": 775.6,\n    "end_time": 777.34,\n    "text": "我們給大家整理了一張表"\n  },\n  {\n    "start_time": 777.34,\n    "end_time": 779.48,\n    "text": "並且在這個表裡面標註了"\n  },\n  {\n    "start_time": 779.48,\n    "end_time": 782.4,\n    "text": "每一種應用層協議它是使用的"\n  },\n  {\n    "start_time": 782.4,\n    "end_time": 783.88,\n    "text": "運輸層的哪一個協議"\n  },\n  {\n    "start_time": 783.88,\n    "end_time": 786.6,\n    "text": "以及它連接的一個剛頭號分別是多少"\n  },\n  {\n    "start_time": 787.06,\n    "end_time": 789.46,\n    "text": "這個咱們沒有一個很好的記憶方法"\n  },\n  {\n    "start_time": 789.46,\n    "end_time": 791.62,\n    "text": "只能靠大家自己去背著"\n  },\n  {\n    "start_time": 792.34,\n    "end_time": 794.34,\n    "text": "所以這張表是非常重要的"\n  },\n  {\n    "start_time": 794.34,\n    "end_time": 795.94,\n    "text": "你基本上長了這張表"\n  },\n  {\n    "start_time": 795.94,\n    "end_time": 798.1,\n    "text": "對於咱們這一張的內容"\n  },\n  {\n    "start_time": 798.1,\n    "end_time": 799.4,\n    "text": "你在作題的時候"\n  },\n  {\n    "start_time": 799.4,\n    "end_time": 801.4,\n    "text": "就已經找到了80%"\n  },\n  {\n    "start_time": 801.4,\n    "end_time": 802.92,\n    "text": "所以大家一定要記清楚"\n  },\n  {\n    "start_time": 803.84,\n    "end_time": 805.62,\n    "text": "那最後我們是招救"\n  },\n  {\n    "start_time": 805.62,\n    "end_time": 807.46,\n    "text": "給大家留了幾道練習題"\n  },\n  {\n    "start_time": 807.46,\n    "end_time": 809.16,\n    "text": "大家先自行練習一下"\n  },\n  {\n    "start_time": 809.16,\n    "end_time": 810.62,\n    "text": "我們A會公布答案"\n  },\n  {\n    "start_time": 826.4,\n    "end_time": 827.66,\n    "text": "好答案公布"\n  },\n  {\n    "start_time": 827.66,\n    "end_time": 830.14,\n    "text": "大家可以看一下你做對了嗎"\n  },\n  {\n    "start_time": 830.94,\n    "end_time": 833.06,\n    "text": "我們上通這裡也要恭喜"\n  },\n  {\n    "start_time": 833.06,\n    "end_time": 836.74,\n    "text": "我們考試內容是前6招的小夥伴們"\n  },\n  {\n    "start_time": 836.74,\n    "end_time": 839.82,\n    "text": "到這裡你的課程就已經結束了"\n  },\n  {\n    "start_time": 839.82,\n    "end_time": 842.3,\n    "text": "最後預祝大家在新墨垮式裡面"\n  },\n  {\n    "start_time": 842.3,\n    "end_time": 844.02,\n    "text": "都能取得一個好成績"\n  },\n  {\n    "start_time": 844.02,\n    "end_time": 846.72,\n    "text": "那考試範圍是前7張的小夥伴"\n  },\n  {\n    "start_time": 846.72,\n    "end_time": 848.84,\n    "text": "也不要著急我們還有一張內容"\n  },\n  {\n    "start_time": 848.84,\n    "end_time": 850.6,\n    "text": "那我們下一節再見"\n  }\n]'}]}]}}
